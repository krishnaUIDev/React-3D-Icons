{
  "name": "r3d-icons",
  "version": "1.1.8",
  "description": "Premium, customizable, high-definition 3D icons built with React Three Fiber",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "author": "Krishna Kondoju",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/krishnaUIDev/React-3D-Icons.git"
  },
  "bugs": {
    "url": "https://github.com/krishnaUIDev/React-3D-Icons/issues"
  },
  "homepage": "https://github.com/krishnaUIDev/React-3D-Icons#readme",
  "keywords": [
    "react",
    "3d",
    "icons",
    "threejs",
    "r3f",
    "react-three-fiber",
    "customizable",
    "glassmorphism",
    "materials",
    "design-system"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@react-three/drei": ">=9.0.0",
    "@react-three/fiber": ">=8.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "three": ">=0.150.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/three": "^0.166.0",
    "tsup": "^8.1.0",
    "typescript": "^5.4.5"
  }
}
